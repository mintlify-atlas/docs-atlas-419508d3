  "keyFeatures": [
    "Complete educational compiler with all compilation phases",
    "Lexical, syntactic, and semantic analysis",
    "Three-address code intermediate representation",
    "Built-in interpreter for real-time execution",
    "x86 assembly code generation (EMU8086 compatible)",
    "Both CLI and GUI interfaces with syntax highlighting",
    "Comprehensive error detection and reporting"
  ],
  "publicApiSurface": [
    "Scanner - Lexical analysis (tokenization)",
    "Parser - Syntactic analysis (AST construction)",
    "AnalizadorSemantico - Semantic validation",
    "GeneradorIR - Intermediate representation generation",
    "Interprete - Code interpretation and execution",
    "GeneradorASM - x86 assembly code generation",
    "compilar() - Main compilation function",
    "InterfazCompilador - GUI application class"
